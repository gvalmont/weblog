---
import type { MarkdownHeading } from "astro";
import type { CollectionEntry } from "astro:content";
import CusdisComments from "@/components/CusdisComments.astro";
import ShareLinks from "@/components/ShareLinks.astro";
import { formatDate } from "@/lib/posts";
import BaseLayout from "./BaseLayout.astro";

interface Props {
  post: CollectionEntry<"blog">;
  headings: MarkdownHeading[];
}

const { post, headings } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  canonical={canonical}
  type="article"
  publishedTime={post.data.pubDate}
  modifiedTime={post.data.updatedDate}
  tags={post.data.tags}
>
  <article>
    <header class="post-header">
      <h1>{post.data.title}</h1>
      <p class="post-meta">
        Posted {formatDate(post.data.pubDate)}
        {post.data.updatedDate && <> · Updated {formatDate(post.data.updatedDate)}</>}
      </p>
      {post.data.tags.length > 0 && (
        <ul class="tag-list" aria-label="Tags">
          {post.data.tags.map((tag) => (
            <li><a href={`/tags/${encodeURIComponent(tag)}/`}>{tag}</a></li>
          ))}
        </ul>
      )}
    </header>
    {headings.length > 0 && (
      <nav class="post-toc" aria-label="Table of contents">
        <h2>Contents</h2>
        <ol>
          {headings.map((heading) => (
            <li class={`toc-depth-${heading.depth}`}>
              <a href={`#${heading.slug}`}>{heading.text}</a>
            </li>
          ))}
        </ol>
      </nav>
    )}
    <div class="post-body">
      <slot />
    </div>
  </article>
  <ShareLinks title={post.data.title} url={canonical.href} />
  <CusdisComments pageId={canonical.pathname} pageTitle={post.data.title} pageUrl={canonical.href} />

  <script>
    for (const heading of document.querySelectorAll(".post-body h2[id], .post-body h3[id]")) {
      if (heading.querySelector(":scope > .heading-self-link")) {
        continue;
      }

      const link = document.createElement("a");
      const title = heading.textContent?.trim();

      link.className = "heading-self-link";
      link.href = `#${heading.id}`;

      if (title) {
        link.setAttribute("aria-label", `${title} section link`);
      }

      while (heading.firstChild) {
        link.appendChild(heading.firstChild);
      }

      heading.appendChild(link);
    }
  </script>
</BaseLayout>
