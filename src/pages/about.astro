---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="About" description="About this blog and how to subscribe.">
  <h1>About</h1>
  <p>This is a minimalist personal blog built with Astro.</p>
  <h2>Subscribe</h2>
  <p>
    You can subscribe by <a href="/subscribe/">email</a> (handled by Buttondown) or with any feed reader
    using the <a href="/rss.xml">RSS feed</a>.
  </p>
  <h2>Comments</h2>
  <p>
    Comments are handled by Cusdis Cloud. Readers can comment without creating an account on this
    site, and comments are moderated before publication.
  </p>
</BaseLayout>
